.page {
  min-height: 100vh;
  padding: 24rpx 22rpx 150rpx;
  background-color: #b8d8c6;
  background-image:
    radial-gradient(circle at 24rpx 24rpx, rgba(150, 127, 86, 0.28) 0 6rpx, transparent 7rpx),
    radial-gradient(circle at 45rpx 20rpx, rgba(150, 127, 86, 0.18) 0 4rpx, transparent 5rpx);
  background-size: 92rpx 92rpx;
  color: #6b4528;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin: 0 auto;
  padding: 32rpx 30rpx 28rpx;
  border: 5rpx solid #7a5732;
  border-bottom: 0;
  border-radius: 14rpx 14rpx 0 0;
  background: #f5ead0;
}

.brand {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.brand-icon {
  display: none;
}

.brand-title {
  color: #6b4528;
  font-family: "Times New Roman", "STKaiti", "Kaiti SC", serif;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.05;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

.brand-sub {
  display: inline-block;
  margin-top: 8rpx;
  padding: 0 18rpx 10rpx;
  border-bottom: 2rpx solid #a98255;
  color: #8c6840;
  font-size: 27rpx;
  font-weight: 700;
}

.top-action {
  min-width: 116rpx;
  margin: 0;
  border: 3rpx solid #7a5732;
  border-radius: 999rpx;
  background: #f8efd9;
  color: #6b4528;
  font-family: "Times New Roman", "STKaiti", "Kaiti SC", serif;
  font-size: 25rpx;
  font-weight: 700;
}

.top-action.active {
  background: #a8cdb5;
  color: #315b42;
}

.status {
  display: flex;
  gap: 18rpx;
  margin: 0 auto;
  padding: 24rpx 30rpx;
  border-left: 5rpx solid #7a5732;
  border-right: 5rpx solid #7a5732;
  border-top: 3rpx dashed #c7a677;
  background: #f5ead0;
}

.status-chip {
  align-self: flex-start;
  flex-shrink: 0;
  padding: 9rpx 18rpx;
  border: 3rpx solid #91b99f;
  border-radius: 999rpx;
  background: #e7f0df;
  color: #315b42;
  font-size: 22rpx;
  font-weight: 700;
}

.status.warn .status-chip {
  border-color: #d3b177;
  background: #f3deb1;
  color: #7a5732;
}

.status.error .status-chip {
  border-color: #d9816e;
  background: #ffe1c5;
  color: #8f3f2f;
}

.status-copy {
  flex: 1;
  min-width: 0;
}

.status-title {
  color: #6b4528;
  font-size: 28rpx;
  font-weight: 700;
}

.status-text {
  margin-top: 8rpx;
  color: #8c6840;
  font-size: 24rpx;
  line-height: 1.5;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 0 auto;
  padding: 18rpx 30rpx 22rpx;
  border-left: 5rpx solid #7a5732;
  border-right: 5rpx solid #7a5732;
  border-top: 3rpx dashed #c7a677;
  background: #f5ead0;
}

.avatar-picker {
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
  margin: 0;
  padding: 0;
  overflow: hidden;
  border: 4rpx solid #8b6840;
  border-radius: 50%;
  background: #d09a6b;
}

.avatar-picker::after {
  border: 0;
}

.profile-avatar {
  width: 84rpx;
  height: 84rpx;
  display: block;
}

.profile-avatar.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff7e8;
  font-size: 20rpx;
  font-weight: 700;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-label {
  color: #6b4528;
  font-size: 25rpx;
  font-weight: 700;
}

.nickname-input {
  min-height: 56rpx;
  margin-top: 8rpx;
  padding: 0 18rpx;
  border: 3rpx solid #c7a677;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #6b4528;
  font-size: 25rpx;
  font-weight: 700;
}

.tools {
  margin: 0 auto;
  padding: 20rpx 30rpx 26rpx;
  border-left: 5rpx solid #7a5732;
  border-right: 5rpx solid #7a5732;
  background: #f5ead0;
}

.search {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 82rpx;
  padding: 0 26rpx;
  border: 3rpx solid #c7a677;
  border-radius: 999rpx;
  background: #fff7e8;
}

.search input {
  flex: 1;
  min-width: 0;
  color: #6b4528;
  font-size: 30rpx;
}

.search-icon {
  color: #a98255;
  font-size: 28rpx;
  font-weight: 700;
}

.clear-btn {
  width: 54rpx;
  min-width: 54rpx;
  height: 54rpx;
  padding: 0;
  border: 2rpx solid #c7a677;
  border-radius: 50%;
  background: #f5ead0;
  color: #7a5732;
}

.tool-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tool-btn {
  flex-shrink: 0;
  min-width: 132rpx;
  margin: 0;
  border: 3rpx solid #c7a677;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #6b4528;
  font-size: 25rpx;
  font-weight: 700;
}

.tool-btn.primary {
  border-color: #7a5732;
  background: #8b6840;
  color: #fff7e8;
}

.menu-title {
  margin: 0 auto;
  padding: 22rpx 34rpx 12rpx;
  border-left: 5rpx solid #7a5732;
  border-right: 5rpx solid #7a5732;
  background: #f5ead0;
  color: #6b4528;
  font-size: 38rpx;
  font-weight: 700;
  text-decoration: underline;
  text-decoration-color: #b99466;
  text-underline-offset: 8rpx;
}

.list {
  margin: 0 auto;
  padding: 0 30rpx 34rpx;
  border-left: 5rpx solid #7a5732;
  border-right: 5rpx solid #7a5732;
  border-bottom: 5rpx solid #7a5732;
  border-radius: 0 0 14rpx 14rpx;
  background: #f5ead0;
}

.card {
  margin-bottom: 26rpx;
  overflow: hidden;
  border: 5rpx solid #8b6840;
  border-radius: 14rpx;
  background: #fff7e8;
  box-shadow: 8rpx 8rpx 0 rgba(122, 87, 50, 0.22);
}

.card-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 142rpx;
  padding: 24rpx;
}

.drink-emoji {
  width: 110rpx;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 5rpx solid #8b6840;
  border-radius: 12rpx;
  background: #d09a6b;
  font-size: 52rpx;
}

.drink-icon-photo {
  width: 110rpx;
  height: 110rpx;
  flex-shrink: 0;
  border: 5rpx solid #8b6840;
  border-radius: 12rpx;
  background: #d09a6b;
}

.drink-main {
  flex: 1;
  min-width: 0;
}

.drink-name {
  overflow: hidden;
  color: #6b4528;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drink-price {
  display: inline-block;
  margin-top: 12rpx;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  background: #d9816e;
  color: #fff7e8;
  font-size: 28rpx;
  font-weight: 700;
}

.chev {
  width: 72rpx;
  color: #8c6840;
  font-size: 24rpx;
  font-weight: 700;
  text-align: right;
}

.card-body {
  padding: 24rpx;
  border-top: 3rpx dashed #c7a677;
}

.image-tools {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.image-btn {
  flex: 1;
  margin: 0;
  border: 3rpx solid #91b99f;
  border-radius: 999rpx;
  background: #d8e8d0;
  color: #315b42;
  font-size: 24rpx;
  font-weight: 700;
}

.image-btn.danger {
  border-color: #d9816e;
  background: #ffe1c5;
  color: #8f3f2f;
}

.section-title {
  display: inline-block;
  margin: 28rpx 0 16rpx;
  border-bottom: 2rpx solid #b99466;
  color: #6b4528;
  font-size: 31rpx;
  font-weight: 700;
}

.section-title:first-child {
  margin-top: 0;
}

.ingredient-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 58rpx;
  color: #6b4528;
  font-size: 29rpx;
  font-weight: 700;
}

.dot {
  width: 13rpx;
  height: 13rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #8b6840;
}

.ingredient-name {
  flex: 1;
  min-width: 0;
}

.amount {
  padding: 5rpx 17rpx;
  border-radius: 999rpx;
  background: #a8cdb5;
  color: #315b42;
  font-size: 25rpx;
  font-weight: 700;
}

.step-row {
  display: flex;
  gap: 18rpx;
  margin-bottom: 22rpx;
  color: #6b4528;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.55;
}

.step-no {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 5rpx solid #6b4528;
  border-radius: 50%;
  background: #8b6840;
  color: #fff7e8;
  font-size: 25rpx;
  font-weight: 700;
}

.note-row {
  margin-top: 14rpx;
  padding: 22rpx 24rpx;
  border: 4rpx solid #d9816e;
  border-radius: 10rpx;
  background: #ffe6bf;
  color: #6b4528;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.55;
}

.history-heading {
  margin-top: 34rpx;
}

.history-empty {
  padding: 20rpx 22rpx;
  border: 3rpx dashed #c7a677;
  border-radius: 12rpx;
  background: #fffaf0;
  color: #8c6840;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.history-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
  border-top: 2rpx dashed #d8bd91;
}

.history-row:first-of-type {
  border-top: 0;
}

.history-avatar {
  width: 62rpx;
  height: 62rpx;
  flex-shrink: 0;
  border: 3rpx solid #8b6840;
  border-radius: 50%;
  background: #d09a6b;
}

.history-avatar.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff7e8;
  font-size: 25rpx;
  font-weight: 700;
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.history-name {
  color: #6b4528;
  font-size: 26rpx;
  font-weight: 700;
}

.history-time {
  flex-shrink: 0;
  color: #a98255;
  font-size: 22rpx;
  font-weight: 700;
}

.history-summary {
  margin-top: 6rpx;
  color: #8c6840;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.emoji-edit,
.edit-row,
.edit-step,
.edit-note {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.emoji-edit text {
  color: #8c6840;
  font-size: 24rpx;
  font-weight: 700;
}

.emoji-edit input {
  width: 96rpx;
}

.edit-title,
.edit-price,
.edit-input,
.edit-step input,
.edit-note input,
.emoji-edit input {
  min-height: 68rpx;
  padding: 0 16rpx;
  border: 3rpx solid #c7a677;
  border-radius: 10rpx;
  background: #fffaf0;
  color: #6b4528;
  font-size: 27rpx;
  font-weight: 700;
}

.edit-title {
  width: 100%;
  font-size: 31rpx;
}

.edit-price {
  width: 170rpx;
  margin-top: 10rpx;
  color: #9b4b3f;
}

.edit-input.name {
  flex: 1;
  min-width: 0;
}

.amount-input {
  width: 188rpx;
}

.edit-step input,
.edit-note input {
  flex: 1;
  min-width: 0;
}

.icon-btn {
  width: 58rpx;
  min-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border: 3rpx solid #c7a677;
  border-radius: 50%;
  background: #f5ead0;
  color: #7a5732;
}

.add-line {
  margin: 12rpx 0 10rpx;
  border: 3rpx dashed #c7a677;
  border-radius: 10rpx;
  background: #fff7e8;
  color: #6b4528;
  font-size: 25rpx;
  font-weight: 700;
}

.danger.ghost {
  margin-left: auto;
  border: 3rpx solid #d9816e;
  border-radius: 10rpx;
  color: #8f3f2f;
  background: #ffe1c5;
}

.fab {
  position: fixed;
  right: 34rpx;
  bottom: 46rpx;
  z-index: 8;
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 5rpx solid #6b4528;
  border-radius: 50%;
  background: #a8cdb5;
  color: #315b42;
  font-size: 54rpx;
  box-shadow: 8rpx 8rpx 0 rgba(122, 87, 50, 0.24);
}

.reset-btn {
  position: fixed;
  left: 34rpx;
  bottom: 54rpx;
  z-index: 8;
  border: 3rpx solid #c7a677;
  border-radius: 999rpx;
  background: #fff7e8;
  color: #6b4528;
  font-weight: 700;
}
