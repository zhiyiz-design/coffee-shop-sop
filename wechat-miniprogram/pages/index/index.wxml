<view class="page">
  <view class="topbar">
    <view class="brand">
      <view class="brand-icon">☕</view>
      <view>
        <view class="brand-title">咖啡店 SOP</view>
        <view class="brand-sub">标准操作手册</view>
      </view>
    </view>
    <button wx:if="{{viewMode}}" class="top-action" size="mini" bindtap="toggleEdit">编辑</button>
    <button wx:if="{{editMode}}" class="top-action active" size="mini" bindtap="toggleEdit">完成</button>
  </view>

  <view class="status {{status.cls}}">
    <view class="status-chip">{{status.chip}}</view>
    <view class="status-copy">
      <view class="status-title">{{status.title}}</view>
      <view class="status-text">{{status.text}}</view>
    </view>
  </view>

  <view class="tools">
    <view class="search">
      <text class="search-icon">搜</text>
      <input value="{{query}}" confirm-type="search" placeholder="搜索饮品、原料或步骤" bindinput="onSearch" />
      <button wx:if="{{query}}" class="clear-btn" size="mini" bindtap="clearSearch">x</button>
    </view>
    <view class="tool-row">
      <button class="tool-btn primary" loading="{{loading}}" bindtap="refreshCloud">刷新</button>
      <button class="tool-btn primary" loading="{{loading}}" bindtap="saveCloud">保存云端</button>
      <button class="tool-btn" loading="{{loading}}" bindtap="exportPdf">导出PDF</button>
      <button class="tool-btn" bindtap="expandAll">展开全部</button>
      <button class="tool-btn" bindtap="exportBackup">导出</button>
      <button class="tool-btn" bindtap="importBackup">导入</button>
    </view>
  </view>

  <view class="list">
    <block wx:for="{{visibleDrinks}}" wx:for-item="drink" wx:key="id">
      <view class="card">
        <view class="card-head" data-id="{{drink.id}}" bindtap="toggleCard">
          <image wx:if="{{drink.hasImage}}" class="drink-icon-photo" src="{{drink.img}}" mode="aspectFill" data-src="{{drink.img}}" catchtap="previewDrinkImage" />
          <view wx:if="{{drink.noImage}}" class="drink-emoji">{{drink.emoji}}</view>
          <view class="drink-main">
            <view wx:if="{{viewMode}}" class="drink-name">{{drink.name}}</view>
            <input wx:if="{{editMode}}" class="edit-title" value="{{drink.name}}" data-id="{{drink.id}}" data-field="name" bindinput="updateDrinkField" />
            <view wx:if="{{viewMode}}" class="drink-price">{{drink.price}}</view>
            <input wx:if="{{editMode}}" class="edit-price" value="{{drink.price}}" data-id="{{drink.id}}" data-field="price" bindinput="updateDrinkField" />
          </view>
          <view class="chev">{{drink.actionText}}</view>
        </view>

        <view wx:if="{{drink.open}}" class="card-body">
          <view wx:if="{{editMode}}" class="image-tools">
            <button class="image-btn" size="mini" data-id="{{drink.id}}" bindtap="chooseDrinkImage">上传/更换头像照片</button>
            <button wx:if="{{drink.hasImage}}" class="image-btn danger" size="mini" data-id="{{drink.id}}" bindtap="removeDrinkImage">删除头像</button>
          </view>

          <view wx:if="{{editMode}}" class="emoji-edit">
            <text>备用emoji</text>
            <input value="{{drink.emoji}}" data-id="{{drink.id}}" data-field="emoji" bindinput="updateDrinkField" />
            <button class="danger ghost" size="mini" data-id="{{drink.id}}" bindtap="deleteDrink">删除饮品</button>
          </view>

          <view class="section-title">原料配方</view>
          <block wx:for="{{drink.ingredientViews}}" wx:for-item="ingredient" wx:key="uid">
            <view wx:if="{{viewMode}}" class="ingredient-row">
              <view class="dot"></view>
              <view class="ingredient-name">{{ingredient.name}}</view>
              <view class="amount">{{ingredient.amount}}</view>
            </view>
            <view wx:if="{{editMode}}" class="edit-row">
              <input class="edit-input name" value="{{ingredient.name}}" placeholder="原料" data-id="{{drink.id}}" data-index="{{ingredient.index}}" data-field="name" bindinput="updateIngredient" />
              <input class="edit-input amount-input" value="{{ingredient.amount}}" placeholder="用量" data-id="{{drink.id}}" data-index="{{ingredient.index}}" data-field="amount" bindinput="updateIngredient" />
              <button class="icon-btn" size="mini" data-id="{{drink.id}}" data-index="{{ingredient.index}}" bindtap="removeIngredient">x</button>
            </view>
          </block>
          <button wx:if="{{editMode}}" class="add-line" size="mini" data-id="{{drink.id}}" bindtap="addIngredient">+ 原料</button>

          <view class="section-title">制作步骤</view>
          <block wx:for="{{drink.stepViews}}" wx:for-item="step" wx:key="uid">
            <view wx:if="{{viewMode}}" class="step-row">
              <view class="step-no">{{step.no}}</view>
              <view class="step-text">{{step.text}}</view>
            </view>
            <view wx:if="{{editMode}}" class="edit-step">
              <view class="step-no">{{step.no}}</view>
              <input value="{{step.text}}" placeholder="步骤说明" data-id="{{drink.id}}" data-index="{{step.index}}" bindinput="updateStep" />
              <button class="icon-btn" size="mini" data-id="{{drink.id}}" data-index="{{step.index}}" bindtap="removeStep">x</button>
            </view>
          </block>
          <button wx:if="{{editMode}}" class="add-line" size="mini" data-id="{{drink.id}}" bindtap="addStep">+ 步骤</button>

          <view wx:if="{{drink.showNotes}}" class="section-title">注意事项</view>
          <block wx:for="{{drink.noteViews}}" wx:for-item="note" wx:key="uid">
            <view wx:if="{{viewMode}}" class="note-row">{{note.text}}</view>
            <view wx:if="{{editMode}}" class="edit-note">
              <input value="{{note.text}}" placeholder="注意事项" data-id="{{drink.id}}" data-index="{{note.index}}" bindinput="updateNote" />
              <button class="icon-btn" size="mini" data-id="{{drink.id}}" data-index="{{note.index}}" bindtap="removeNote">x</button>
            </view>
          </block>
          <button wx:if="{{editMode}}" class="add-line" size="mini" data-id="{{drink.id}}" bindtap="addNote">+ 注意事项</button>
        </view>
      </view>
    </block>
  </view>

  <button wx:if="{{editMode}}" class="fab" bindtap="addDrink">+</button>
  <button wx:if="{{editMode}}" class="reset-btn" size="mini" bindtap="resetDefault">恢复默认</button>
</view>
