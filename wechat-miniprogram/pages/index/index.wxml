<view class="page">
  <view class="topbar">
    <view class="brand">
      <view class="brand-icon">☕</view>
      <view>
        <view class="brand-title">咖啡店 SOP</view>
        <view class="brand-sub">标准操作手册</view>
      </view>
    </view>
    <button class="top-action {{editMode ? 'active' : ''}}" size="mini" bindtap="toggleEdit">{{editMode ? '完成' : '编辑'}}</button>
  </view>

  <view class="status {{status.cls}}">
    <view class="status-chip">{{status.chip}}</view>
    <view class="status-copy">
      <view class="status-title">{{status.title}}</view>
      <view class="status-text">{{status.text}}</view>
    </view>
  </view>

  <view class="tools">
    <view class="search">
      <text class="search-icon">⌕</text>
      <input value="{{query}}" confirm-type="search" placeholder="搜索饮品、原料或步骤" bindinput="onSearch" />
      <button wx:if="{{query}}" class="clear-btn" size="mini" bindtap="clearSearch">×</button>
    </view>
    <view class="tool-row">
      <button class="tool-btn primary" loading="{{loading}}" bindtap="refreshCloud">刷新</button>
      <button class="tool-btn primary" loading="{{loading}}" bindtap="saveCloud">保存云端</button>
      <button class="tool-btn" bindtap="expandAll">展开全部</button>
      <button class="tool-btn" bindtap="exportBackup">导出</button>
      <button class="tool-btn" bindtap="importBackup">导入</button>
    </view>
  </view>

  <view class="list">
    <block wx:for="{{visibleDrinks}}" wx:for-item="drink" wx:key="id">
      <view class="card">
        <view class="card-head" data-id="{{drink.id}}" bindtap="toggleCard">
          <view class="drink-emoji">{{drink.emoji}}</view>
          <view class="drink-main">
            <view wx:if="{{!editMode}}" class="drink-name">{{drink.name}}</view>
            <input wx:else class="edit-title" value="{{drink.name}}" data-id="{{drink.id}}" data-field="name" bindinput="updateDrinkField" />
            <view wx:if="{{!editMode}}" class="drink-price">{{drink.price}}</view>
            <input wx:else class="edit-price" value="{{drink.price}}" data-id="{{drink.id}}" data-field="price" bindinput="updateDrinkField" />
          </view>
          <view class="chev {{drink.open ? 'open' : ''}}">›</view>
        </view>

        <view wx:if="{{drink.open}}" class="card-body">
          <view wx:if="{{editMode}}" class="emoji-edit">
            <text>图标</text>
            <input value="{{drink.emoji}}" data-id="{{drink.id}}" data-field="emoji" bindinput="updateDrinkField" />
            <button class="danger ghost" size="mini" data-id="{{drink.id}}" bindtap="deleteDrink">删除饮品</button>
          </view>

          <view class="section-title">原料配方</view>
          <block wx:for="{{drink.ingredients}}" wx:for-item="ingredient" wx:for-index="ingIndex" wx:key="ingIndex">
            <view wx:if="{{!editMode}}" class="ingredient-row">
              <view class="dot"></view>
              <view class="ingredient-name">{{ingredient.name}}</view>
              <view class="amount">{{ingredient.amount}}</view>
            </view>
            <view wx:else class="edit-row">
              <input class="edit-input name" value="{{ingredient.name}}" placeholder="原料" data-id="{{drink.id}}" data-index="{{ingIndex}}" data-field="name" bindinput="updateIngredient" />
              <input class="edit-input amount-input" value="{{ingredient.amount}}" placeholder="用量" data-id="{{drink.id}}" data-index="{{ingIndex}}" data-field="amount" bindinput="updateIngredient" />
              <button class="icon-btn" size="mini" data-id="{{drink.id}}" data-index="{{ingIndex}}" bindtap="removeIngredient">×</button>
            </view>
          </block>
          <button wx:if="{{editMode}}" class="add-line" size="mini" data-id="{{drink.id}}" bindtap="addIngredient">+ 原料</button>

          <view class="section-title">制作步骤</view>
          <block wx:for="{{drink.steps}}" wx:for-item="step" wx:for-index="stepIndex" wx:key="stepIndex">
            <view wx:if="{{!editMode}}" class="step-row">
              <view class="step-no">{{stepIndex + 1}}</view>
              <view class="step-text">{{step}}</view>
            </view>
            <view wx:else class="edit-step">
              <view class="step-no">{{stepIndex + 1}}</view>
              <input value="{{step}}" placeholder="步骤说明" data-id="{{drink.id}}" data-index="{{stepIndex}}" bindinput="updateStep" />
              <button class="icon-btn" size="mini" data-id="{{drink.id}}" data-index="{{stepIndex}}" bindtap="removeStep">×</button>
            </view>
          </block>
          <button wx:if="{{editMode}}" class="add-line" size="mini" data-id="{{drink.id}}" bindtap="addStep">+ 步骤</button>

          <view wx:if="{{drink.hasNotes || editMode}}" class="section-title">注意事项</view>
          <block wx:for="{{drink.notes}}" wx:for-item="note" wx:for-index="noteIndex" wx:key="noteIndex">
            <view wx:if="{{!editMode}}" class="note-row">{{note}}</view>
            <view wx:else class="edit-note">
              <input value="{{note}}" placeholder="注意事项" data-id="{{drink.id}}" data-index="{{noteIndex}}" bindinput="updateNote" />
              <button class="icon-btn" size="mini" data-id="{{drink.id}}" data-index="{{noteIndex}}" bindtap="removeNote">×</button>
            </view>
          </block>
          <button wx:if="{{editMode}}" class="add-line" size="mini" data-id="{{drink.id}}" bindtap="addNote">+ 注意事项</button>
        </view>
      </view>
    </block>
  </view>

  <button wx:if="{{editMode}}" class="fab" bindtap="addDrink">+</button>
  <button wx:if="{{editMode}}" class="reset-btn" size="mini" bindtap="resetDefault">恢复默认</button>
</view>
